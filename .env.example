# Copy to .env and fill values before starting the backend.

# App
NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/assuredcontractfarming
JWT_SECRET=changeme

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password

# Optional alternate SMTP
ALT_SMTP_HOST=
ALT_SMTP_PORT=
ALT_SMTP_SECURE=
ALT_SMTP_USER=
ALT_SMTP_PASS=

# Optional Twilio fallback
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# AI / translation providers
GEMINI_API_KEY=your_gemini_api_key
LIBRETRANSLATE_URL=
